---
---

<section class="logo-strip">
  <p class="logo-strip-label animate-fade-in">Built on</p>
  <div class="logo-strip-grid animate-fade-in delay-100">
    <div class="tech-logo" title="Amazon Web Services">
      <svg width="40" height="24" viewBox="0 0 40 24" fill="currentColor">
        <path d="M11.2 9.6c0 .5.1.8.2 1.1.1.2.3.5.5.8l-.7.5c-.2.1-.3.1-.4 0-.2-.3-.4-.5-.5-.8-.5.6-1.1.9-1.8.9-.9 0-1.6-.7-1.6-1.7 0-1.1.8-1.8 2.3-1.8h.7V8c0-.5-.1-.8-.3-1-.2-.2-.6-.3-1.1-.3-.5 0-1 .1-1.5.4-.2.1-.3.1-.4-.1l-.2-.4c.6-.4 1.3-.6 2.1-.6.8 0 1.3.2 1.7.5.4.4.6.9.6 1.6v2.5zm-2.5.5c.4 0 .9-.2 1.2-.5.2-.2.3-.5.3-.9v-.4h-.6c-.6 0-1 .1-1.3.3-.3.2-.4.5-.4.8 0 .2.1.4.2.5.2.1.4.2.6.2z"/>
        <path d="M15.9 11.3c-.1.1-.3.1-.5 0-.4-.3-.7-.7-.7-1.4V6.8h-1.2c-.1 0-.2-.1-.2-.2V6.2c0-.1.1-.2.2-.2h1.2V4.6c0-.1.1-.2.2-.2l.6-.1c.1 0 .2.1.2.2V6h1.5c.1 0 .2.1.2.2v.4c0 .1-.1.2-.2.2h-1.5v3c0 .4.2.6.6.6.2 0 .4-.1.5-.1.1-.1.2-.1.3 0l.2.4c-.3.4-.7.5-1.1.6z"/>
        <path d="M19.8 11.6c-.9 0-1.6-.2-2.1-.7-.5-.5-.8-1.1-.8-2s.3-1.6.8-2.1c.5-.5 1.2-.8 2-.8s1.5.3 2 .8c.5.5.7 1.2.7 2 0 .1 0 .2-.1.2h-4.2c0 .6.2 1.1.5 1.4.4.3.8.5 1.4.5.6 0 1.1-.2 1.6-.5.1-.1.2-.1.3 0l.3.4c-.3.3-.6.4-.9.5-.4.2-.8.3-1.5.3zm1.5-3.3c0-.5-.2-.9-.5-1.2-.3-.3-.7-.5-1.1-.5-.5 0-.9.2-1.2.5-.3.3-.5.7-.5 1.2h3.3z"/>
        <text x="3" y="20" font-size="6" font-weight="700" letter-spacing="0.5">AWS</text>
      </svg>
    </div>

    <div class="tech-logo" title="TypeScript">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
        <rect width="24" height="24" rx="3" fill="currentColor" opacity="0.15"/>
        <text x="12" y="16" font-size="10" font-weight="700" text-anchor="middle" fill="currentColor">TS</text>
      </svg>
    </div>

    <div class="tech-logo" title="React">
      <svg width="26" height="24" viewBox="0 0 26 24" fill="none" stroke="currentColor" stroke-width="1">
        <ellipse cx="13" cy="12" rx="11" ry="4.5"/>
        <ellipse cx="13" cy="12" rx="11" ry="4.5" transform="rotate(60 13 12)"/>
        <ellipse cx="13" cy="12" rx="11" ry="4.5" transform="rotate(120 13 12)"/>
        <circle cx="13" cy="12" r="2" fill="currentColor"/>
      </svg>
    </div>

    <div class="tech-logo" title="DynamoDB">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
        <rect width="24" height="24" rx="3" fill="currentColor" opacity="0.15"/>
        <text x="12" y="16" font-size="7" font-weight="600" text-anchor="middle" fill="currentColor">DB</text>
      </svg>
    </div>

    <div class="tech-logo" title="Kinesis">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
        <rect width="24" height="24" rx="3" fill="currentColor" opacity="0.15"/>
        <path d="M6 8l6 4-6 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        <path d="M12 8l6 4-6 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" opacity="0.5"/>
      </svg>
    </div>

    <div class="tech-logo" title="Node.js">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
        <rect width="24" height="24" rx="3" fill="currentColor" opacity="0.15"/>
        <text x="12" y="16" font-size="7" font-weight="600" text-anchor="middle" fill="currentColor">N</text>
      </svg>
    </div>
  </div>
</section>

<style>
  .logo-strip {
    padding: 3rem 1.5rem;
    text-align: center;
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }

  .logo-strip-label {
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    margin-bottom: 1.5rem;
  }

  .logo-strip-grid {
    display: flex;
    gap: 3rem;
    justify-content: center;
    align-items: center;
    flex-wrap: wrap;
    max-width: 600px;
    margin: 0 auto;
  }

  .tech-logo {
    color: var(--text-muted);
    opacity: 0.5;
    transition: all 0.3s ease;
    cursor: default;
  }

  .tech-logo:hover {
    opacity: 1;
    color: var(--accent-cyan);
  }
</style>
