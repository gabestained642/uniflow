---
const steps = [
  {
    num: '1',
    title: 'Install',
    code: 'npm i -g uniflow',
    description: 'One command to install the CLI globally.',
  },
  {
    num: '2',
    title: 'Deploy',
    code: 'uniflow init && uniflow deploy',
    description: 'Interactive setup generates config, then deploys the full stack to your AWS account.',
  },
  {
    num: '3',
    title: 'Track',
    code: 'client.track({ event: "Signup" })',
    description: 'Start sending events from your app using the JavaScript or Python SDK.',
  },
];
---

<section class="how-it-works">
  <div class="how-inner">
    <div class="section-header animate-fade-in-up">
      <p class="section-label">How it works</p>
      <h2 class="section-title">From zero to CDP<br/><span class="gradient-text">in three steps</span></h2>
    </div>

    <div class="steps">
      {steps.map((step, i) => (
        <div class={`step animate-fade-in-up delay-${(i + 1) * 200}`}>
          <div class="step-indicator">
            <div class="step-number">{step.num}</div>
            {i < steps.length - 1 && <div class="step-line"></div>}
          </div>
          <div class="step-content">
            <h3 class="step-title">{step.title}</h3>
            <div class="step-code">
              <code>{step.code}</code>
            </div>
            <p class="step-desc">{step.description}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .how-it-works {
    padding: 6rem 1.5rem;
    max-width: 1200px;
    margin: 0 auto;
  }

  .section-header {
    text-align: center;
    margin-bottom: 4rem;
  }

  .section-label {
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--accent-cyan);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 1rem;
  }

  .section-title {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    font-weight: 400;
    line-height: 1.2;
    letter-spacing: -0.02em;
  }

  .steps {
    max-width: 560px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .step {
    display: flex;
    gap: 1.5rem;
    position: relative;
  }

  .step-indicator {
    display: flex;
    flex-direction: column;
    align-items: center;
    flex-shrink: 0;
  }

  .step-number {
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-mono);
    font-size: 0.875rem;
    font-weight: 700;
    background: var(--accent-glow);
    color: #0a0a0f;
    flex-shrink: 0;
  }

  .step-line {
    width: 1px;
    flex: 1;
    min-height: 3rem;
    background: linear-gradient(180deg, var(--accent-cyan), transparent);
    opacity: 0.3;
  }

  .step-content {
    padding-bottom: 2.5rem;
  }

  .step-title {
    font-size: 1.125rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
    letter-spacing: -0.01em;
  }

  .step-code {
    display: inline-block;
    padding: 0.375rem 0.75rem;
    border-radius: 0.375rem;
    background: var(--bg-surface);
    border: 1px solid var(--border);
    margin-bottom: 0.75rem;
  }

  .step-code code {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--accent-cyan);
  }

  .step-desc {
    color: var(--text-muted);
    font-size: 0.9rem;
    line-height: 1.5;
  }
</style>
