<script is:inline>
  window.StarlightThemeProvider = (() => {
    const storageKey = 'starlight-theme';
    const storedTheme =
      typeof localStorage !== 'undefined' ? localStorage.getItem(storageKey) : null;

    if (typeof localStorage !== 'undefined' && storedTheme === null) {
      localStorage.setItem(storageKey, 'dark');
    }

    const theme =
      storedTheme === 'light'
        ? 'light'
        : storedTheme === 'dark'
          ? 'dark'
          : window.matchMedia('(prefers-color-scheme: light)').matches
            ? 'light'
            : 'dark';

    document.documentElement.dataset.theme = theme;

    return {
      updatePickers(themeValue = storedTheme === null ? 'dark' : storedTheme || 'auto') {
        document.querySelectorAll('starlight-theme-select').forEach((picker) => {
          const select = picker.querySelector('select');
          if (select) select.value = themeValue;

          const tmpl = document.querySelector('#theme-icons');
          const newIcon = tmpl && tmpl.content.querySelector('.' + themeValue);

          if (newIcon) {
            const oldIcon = picker.querySelector('svg.label-icon');
            if (oldIcon) {
              oldIcon.replaceChildren(...newIcon.cloneNode(true).childNodes);
            }
          }
        });
      },
    };
  })();
</script>

<template id="theme-icons">
  <svg class="label-icon light" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
    <circle cx="12" cy="12" r="4.25" />
    <path d="M12 2.5v2.25M12 19.25v2.25M4.75 4.75l1.6 1.6M17.65 17.65l1.6 1.6M2.5 12h2.25M19.25 12h2.25M4.75 19.25l1.6-1.6M17.65 6.35l1.6-1.6" />
  </svg>
  <svg class="label-icon dark" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
    <path d="M20.5 14.1A8.5 8.5 0 1 1 9.9 3.5a6.8 6.8 0 0 0 10.6 10.6Z" />
  </svg>
  <svg class="label-icon auto" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
    <rect x="3.5" y="4.5" width="17" height="12" rx="2" />
    <path d="M8 19.5h8M10 16.5v3M14 16.5v3" />
  </svg>
</template>
